# SOLO PARA PRUEBAS LOCALES.
# En Render NO subas este archivo con el token real: configura DISCORD_TOKEN
# directo en Render > Environment. Este .env es únicamente para correr el bot
# en tu compu/celular con Termux, si algún día lo necesitas.

DISCORD_TOKEN=pega_aqui_tu_token_del_bot
COMMAND_PREFIX=!
OWNER_ID=
